<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upgrade to Premium"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_main" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Premium unlocks:"
            android:textColor="@color/text_main"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="• Remove all ads\n• Advanced protection options\n• Faster auto-lock\n• Priority updates"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnBuyPremium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Buy Premium"
            android:background="@drawable/bg_primary_button"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnRestore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Restore Purchase"
            android:background="@drawable/bg_secondary_button"
            android:textColor="@color/text_main" />

        <TextView
            android:id="@+id/txtPremiumStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text=""
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>