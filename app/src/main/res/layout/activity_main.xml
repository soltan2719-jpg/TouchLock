<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TouchLock"
            android:textColor="@color/text_main"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="TouchLock is ready."
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <!-- STATUS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="System Status"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSystemStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Ready"
                android:textColor="@color/success"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOverlayStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Overlay permission: Granted"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtUsageStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Usage access: Not granted"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGrantOverlay"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:text="Overlay"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnGrantUsageAccess"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:text="Usage Access"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main" />
            </LinearLayout>
        </LinearLayout>

        <!-- MAIN ACTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Main Action"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStartLockNow"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_circle_primary"
                android:text="🔒&#10;Lock Now"
                android:textAllCaps="false"
                android:textColor="@color/text_main"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStopAll"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_secondary_button"
                android:text="Stop Everything"
                android:textAllCaps="false"
                android:textColor="@color/text_main"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- AUTO START CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-Start"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSelectedApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Selected apps: none"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:id="@+id/scrollSelectedApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chipsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPickApps"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:text="Pick Apps"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnStartMonitor"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:text="Monitor Mode"
                    android:textAllCaps="false"
                    android:textColor="@color/text_main" />
            </LinearLayout>
        </LinearLayout>

        <!-- PROTECTION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Protection"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switchShowUnlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Show unlock button"
                android:textColor="@color/text_main" />

            <Switch
                android:id="@+id/switchDoubleTap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable double tap unlock"
                android:textColor="@color/text_main" />

            <Switch
                android:id="@+id/switchRequirePin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Require PIN to unlock"
                android:textColor="@color/text_main" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="PIN"
                android:textColor="@color/text_main"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtPin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:backgroundTint="@color/text_secondary"
                android:hint="Example: 1234"
                android:inputType="numberPassword"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_secondary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Auto-lock delay (seconds)"
                android:textColor="@color/text_main"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtDelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:backgroundTint="@color/text_secondary"
                android:hint="0 = immediate"
                android:inputType="number"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_secondary" />

            <Button
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_secondary_button"
                android:text="Save Settings"
                android:textAllCaps="false"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <!-- SUPPORT CARD -->
        <LinearLayout
            android:id="@+id/supportContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Support"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="TouchLock is free to use. Premium removes ads and unlocks advanced features."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnPremium"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_primary_button"
                android:text="Upgrade to Premium"
                android:textAllCaps="false"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnTip1"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tip_button"
                        android:text="☕ 1€"
                        android:textAllCaps="false"
                        android:textColor="@color/text_main" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <Button
                        android:id="@+id/btnTip2"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tip_button"
                        android:text="☕ 2€"
                        android:textAllCaps="false"
                        android:textColor="@color/text_main" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <Button
                        android:id="@+id/btnTip5"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tip_button"
                        android:text="❤️ 5€"
                        android:textAllCaps="false"
                        android:textColor="@color/text_main" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- AD -->
        <FrameLayout
            android:id="@+id/adContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp" />

        <!-- INFO -->
        <TextView
            android:id="@+id/txtInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:paddingBottom="22dp"
            android:text="How monitor mode works:\n1. Grant Overlay + Usage Access\n2. Pick apps\n3. Start Monitor Mode\n4. When one of those apps opens, TouchLock starts automatically\n\nUnlock options:\n• Unlock button\n• Double tap\n• PIN if enabled\n• STOP from notification"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>