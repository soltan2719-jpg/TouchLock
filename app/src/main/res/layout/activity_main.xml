<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:padding="20dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TouchLock"
        android:textColor="@color/text_main"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="TouchLock is ready."
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ System Status"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSystemStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ready"
            android:textColor="@color/success"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtOverlayStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Overlay: Granted"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtUsageStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="Usage: Not granted"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="12dp">

        <Button
            android:id="@+id/btnStartLockNow"
            android:layout_width="145dp"
            android:layout_height="145dp"
            android:background="@drawable/bg_circle_primary"
            android:text="🔒&#10;Lock Now"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStopAll"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Stop Everything"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="183dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▶ Auto-Start"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSelectedApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="2"
                android:text="Selected apps: none"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <HorizontalScrollView
                android:id="@+id/scrollSelectedApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chipsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <Button
                android:id="@+id/btnPickApps"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_secondary_button"
                android:text="Pick Apps"
                android:textAllCaps="false"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛡 Quick Tools"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStartMonitor"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_secondary_button"
                android:text="Monitor Mode"
                android:textAllCaps="false"
                android:textColor="@color/text_main" />

            <Button
                android:id="@+id/btnOpenSettings"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_secondary_button"
                android:text="Settings"
                android:textAllCaps="false"
                android:textColor="@color/text_main" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/adContainer"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchShowUnlock"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchDoubleTap"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchRequirePin"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <EditText
            android:id="@+id/edtPin"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <EditText
            android:id="@+id/edtDelay"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnPremium"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnTip1"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnTip2"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnTip5"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnGrantOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnGrantUsageAccess"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnOpenSupport"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </LinearLayout>

</LinearLayout>